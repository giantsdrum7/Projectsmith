# {{ project_name }} — Environment Variables
# Copy to .env and fill in values for local development.
# Generated from src/{{ project_slug }}/config/env_spec.py.
# Generated by scripts/env/generate_env_templates.py.
# See docs/reference/ENV_VARS.md for documentation.

# [mode]
# Runtime mode: offline, local-live, or prod
APP_MODE=offline

# Deployment environment label
APP_ENV=development

# Enable debug helpers and verbose output
DEBUG=true

# [aws]
# Primary AWS region
AWS_REGION={{ aws_region }}

# AWS account ID for resource references
AWS_ACCOUNT_ID=000000000000

# IAM role ARN for OIDC / cross-account deployments
AWS_ROLE_ARN=

# Temporary access key (prefer OIDC over static keys)
AWS_ACCESS_KEY_ID=

# Temporary secret key (prefer OIDC over static keys)
AWS_SECRET_ACCESS_KEY=

# Session token for assumed roles
AWS_SESSION_TOKEN=

# [metadata]
# Primary metadata store selected at project generation
METADATA_STORE={{ metadata_store }}

{% if metadata_store == "dynamodb" %}
# DynamoDB table for doc-level metadata (ACL, title, active version)
DYNAMODB_DOCUMENTS_TABLE=

# DynamoDB table for document versions
DYNAMODB_VERSIONS_TABLE=

# DynamoDB table for ingestion jobs
DYNAMODB_JOBS_TABLE=

# DynamoDB table for review tasks (contradiction/supersession)
DYNAMODB_REVIEW_TABLE=

# DynamoDB table for answer manifests (provenance audit)
DYNAMODB_MANIFESTS_TABLE=

{% elif metadata_store == "postgres" %}
# [postgres]
# Aurora PostgreSQL cluster ARN for RDS Data API calls (Aurora only)
POSTGRES_AURORA_CLUSTER_ARN=

# Enable RDS Data API mode; only Aurora PostgreSQL supports the Data API
POSTGRES_DATA_API_ENABLED=false

# Secrets Manager ARN containing PostgreSQL credentials
POSTGRES_SECRET_ARN=

# PostgreSQL host for non-Data-API mode (standard RDS or direct Aurora connection)
POSTGRES_HOST=localhost

# PostgreSQL port for non-Data-API mode
POSTGRES_PORT=5432

# PostgreSQL database name
POSTGRES_DATABASE={{ project_slug }}

# PostgreSQL username for non-Data-API mode; prefer Secrets Manager in live environments
POSTGRES_USER={{ project_slug }}

# Enable pgvector-backed embeddings/retrieval in PostgreSQL
POSTGRES_PGVECTOR_ENABLED=true

{% endif %}
# Step Functions state machine ARN for the ingestion pipeline
SFN_INGEST_ARN=

# [bedrock]
# Bedrock inference profile ARN for routing
BEDROCK_INFERENCE_PROFILE_ARN=

# Default Bedrock model identifier
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Maximum tokens per LLM response
BEDROCK_MAX_TOKENS=4096

# LLM sampling temperature (0.0 = deterministic)
BEDROCK_TEMPERATURE=0.0

# LLM nucleus sampling threshold
BEDROCK_TOP_P=1.0

# Comma-separated stop sequences for LLM
BEDROCK_STOP_SEQUENCES=

# Maximum retries for Bedrock API calls
BEDROCK_RETRY_MAX=3

# Exponential backoff base (seconds) for Bedrock retries
BEDROCK_RETRY_BACKOFF_BASE=2.0

# Bedrock embedding model for chunk vectorization
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

{% if metadata_store == "dynamodb" %}
# [opensearch]
# OpenSearch Serverless search collection endpoint URL
OPENSEARCH_SEARCH_ENDPOINT=

# OpenSearch Serverless vector collection endpoint URL
OPENSEARCH_VECTOR_ENDPOINT=

# Index name within both OpenSearch collections
OPENSEARCH_INDEX_NAME=chunks-v1

# kNN vector dimension (must match embedding model output)
OPENSEARCH_KNN_DIMENSION=1024

{% endif %}
# [s3]
# Canonical single-bucket datalake (replaces S3_ARTIFACTS/UPLOADS_BUCKET)
S3_DATALAKE_BUCKET=

# KMS CMK ARN for S3 default encryption
S3_KMS_KEY_ARN=

# S3 bucket for build/eval artifacts
S3_ARTIFACTS_BUCKET={{ project_slug }}-artifacts-dev

# S3 bucket for user uploads
S3_UPLOADS_BUCKET={{ project_slug }}-uploads-dev

# AWS region for S3 buckets (may differ from primary region)
S3_REGION={{ aws_region }}

# Presigned URL expiration in seconds
S3_PRESIGNED_URL_EXPIRY=3600

# [secrets]
# Prefix path in AWS Secrets Manager
SECRETS_PREFIX={{ project_slug }}/dev

# Secrets cache time-to-live in seconds
SECRETS_CACHE_TTL=300

# Fall back to env vars when Secrets Manager is unavailable
SECRETS_FALLBACK_TO_ENV=true

# [cognito]
# Cognito user pool identifier
COGNITO_USER_POOL_ID=

# Cognito app client ID
COGNITO_CLIENT_ID=

# Cognito hosted UI domain prefix
COGNITO_DOMAIN=

# OAuth2 callback URL for Cognito
COGNITO_CALLBACK_URL=http://localhost:3000/auth/callback

# Expected JWT audience claim for token validation
JWT_AUDIENCE={{ project_slug }}-local

# [logging]
# Minimum log level
LOG_LEVEL=DEBUG

# Log output format: json or text
LOG_FORMAT=text

# Log output destination: stdout or file
LOG_OUTPUT=stdout

# OpenTelemetry collector gRPC endpoint
OTEL_EXPORTER_ENDPOINT=

# Service name reported to OpenTelemetry
OTEL_SERVICE_NAME={{ project_slug }}

# Sentry Data Source Name for error tracking
SENTRY_DSN=

# [timeouts]
# Default HTTP request timeout
REQUEST_TIMEOUT_SECONDS=30

# Timeout for individual LLM API calls
LLM_TIMEOUT_SECONDS=120

# Timeout for background worker tasks
WORKER_TIMEOUT_SECONDS=300

# Maximum parallel LLM requests
MAX_CONCURRENT_LLM_CALLS=5

# Maximum file upload size in megabytes
MAX_UPLOAD_SIZE_MB=50

# API rate limit per client per minute
RATE_LIMIT_PER_MINUTE=60

# [features]
# Enable evaluation harness
FEATURE_EVAL_ENABLED=false

# Enable frontend serving
FEATURE_FRONTEND_ENABLED=false

# Enable background worker processes
FEATURE_WORKERS_ENABLED=false

# Enable authentication enforcement
FEATURE_AUTH_ENABLED=false

# Enable OpenTelemetry and Sentry integrations
FEATURE_OBSERVABILITY_ENABLED=false

# Enable response caching layer
FEATURE_CACHE_ENABLED=false

# [api]
# API server bind address
API_HOST=0.0.0.0

# API server port
API_PORT=8000

# Number of uvicorn worker processes
API_WORKERS=1

# Comma-separated allowed CORS origins
API_CORS_ORIGINS=*

# Base URL path prefix for all API routes
API_BASE_PATH=/api/v1

# [external]
# Serper.dev API key for web search
SERPER_API_KEY=

# GitHub personal access token for repo operations
GITHUB_TOKEN=

# Slack incoming webhook for notifications
SLACK_WEBHOOK_URL=
