{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "{{ claude_code_model }}",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(uv run ruff *)",
      "Bash(mypy *)",
      "Bash(uv run mypy *)",
      "Bash(pytest *)",
      "Bash(uv run pytest *)",
      "Bash(python *)",
      "Bash(uv *)",
      "Bash(pwsh scripts/*)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(rm -rf*)",
      "Bash(del /s*)",
      "Bash(Remove-Item -Recurse*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(Invoke-WebRequest*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-python.ps1\""
          }
        ]
      }
    ]
  }
}
